---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About Etienne Nel.">
  <header class="mb-10">
    <p class="text-sm font-medium text-blue-600 mb-2">etiennenel.com</p>
    <h1 class="text-3xl font-semibold text-gray-900">About</h1>
  </header>

  <div class="prose prose-gray max-w-2xl">
    <p>
      This is a public archive of me — my notes, research, course material,
      and anything else I want to make permanent and shareable.
    </p>
    <p>
      I'm Etienne Nel, based in Africa. This site is where I store what I'm learning
      and thinking, organised so others can read it too.
    </p>
    <h2>Contact</h2>
    <p>
      Reach me at <a href="mailto:neletienne18@gmail.com">neletienne18@gmail.com</a>.
    </p>
  </div>
</Layout>
