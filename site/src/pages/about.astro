---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About Etienne Nel.">
  <header class="mb-10">
    <p class="text-sm font-medium text-blue-600 mb-2">etiennenel.com</p>
    <h1 class="text-3xl font-semibold text-gray-900">About</h1>
  </header>

  <div class="prose prose-gray max-w-2xl">
    <p>
      Hi — I'm Etienne Nel, a builder and entrepreneur based in Africa.
      I'm interested in AI, technology strategy, and how ideas compound over time.
    </p>
    <p>
      This site is my public knowledge base — notes from courses I'm taking,
      research I'm doing, and thinking I want to make permanent.
    </p>
    <h2>Contact</h2>
    <p>
      Reach me at <a href="mailto:etiennenel@industryone.africa">etiennenel@industryone.africa</a>.
    </p>
  </div>
</Layout>
